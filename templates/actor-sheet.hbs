<div class="sheet-wrapper">
<header class="sheet-header">
  <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}"/>
  <div class="header-fields">
    <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Nome"/></h1>
    <div class="resource-row">
      <div class="resource hp">
        <label>HP</label>
        <div class="resource-content">
          <input type="number" name="system.hp.value" value="{{system.hp.value}}"/>
          <span>/</span>
          <span class="derived">{{system.hp.max}}</span>
        </div>
      </div>
      <div class="resource ac">
        <label>AC</label>
        <span class="derived">{{system.ac.value}}</span>
      </div>
      <div class="resource insanity">
        <label>Insanidade</label>
        <div class="resource-content">
          <button type="button" data-action="adjustInsanity" data-delta="-5">−</button>
          <input type="number" name="system.insanity.value" value="{{system.insanity.value}}" min="0" max="100"/>
          <button type="button" data-action="adjustInsanity" data-delta="5">+</button>
          <span class="insanity-label" style="color: {{system.insanityColor}}">{{system.insanityLabel}}</span>
        </div>
      </div>
    </div>
  </div>
</header>

<nav class="sheet-tabs tabs" data-group="primary">
  {{#each tabs as |tab|}}
  <a class="item {{#if (eq tab.id ../activeTab)}}active{{/if}}" data-tab="{{tab.id}}">{{tab.label}}</a>
  {{/each}}
</nav>

<section class="sheet-body">
  <div class="tab identity" data-group="primary" data-tab="identity" {{#unless (eq activeTab "identity")}}hidden{{/unless}}>
    <div class="grid-2">
      <div class="field">
        <label>Inseto do Complex</label>
        <input type="text" name="system.insect" value="{{system.insect}}" placeholder="Libélula, Escorpião..."/>
      </div>
      <div class="field">
        <label>Facção</label>
        <select name="system.faction">
          {{#each config.factionNames as |name|}}
          <option value="{{name}}" {{#if (eq ../system.faction name)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="field">
      <label>Origem / Background</label>
      {{editor system.origin target="system.origin" engine="prosemirror" button=true editable=editable}}
    </div>
    <div class="field">
      <label>Motivação</label>
      {{editor system.motivation target="system.motivation" engine="prosemirror" button=true editable=editable}}
    </div>
  </div>

  <div class="tab attributes" data-group="primary" data-tab="attributes" {{#unless (eq activeTab "attributes")}}hidden{{/unless}}>
    <div class="points-badge">
      Pontos: <strong>{{system.points.spent}}</strong> / {{config.attributePoints}}
      <span class="hint">(restantes: {{system.points.remaining}} · máx {{config.maxAttribute}} por atributo)</span>
    </div>
    <div class="attr-grid">
      {{#each config.attributes as |attr key|}}
      <div class="attr-card">
        <div class="attr-header">
          <span>{{attr.emoji}} {{attr.abbr}}</span>
          <div class="attr-controls">
            <button type="button" data-action="adjustAttr" data-attr="{{key}}" data-delta="-1">−</button>
            <span class="attr-value">{{lookup ../system.attributes key}}</span>
            <button type="button" data-action="adjustAttr" data-attr="{{key}}" data-delta="1">+</button>
          </div>
        </div>
        <div class="attr-label">{{attr.label}}</div>
      </div>
      {{/each}}
    </div>
    <div class="derived-row">
      <div class="derived-card hp">❤️ HP <strong>{{system.hp.max}}</strong> <small>10 + RES×2</small></div>
      <div class="derived-card ac">🛡️ AC <strong>{{system.ac.value}}</strong> <small>8 + AGI</small></div>
    </div>
  </div>

  <div class="tab complex" data-group="primary" data-tab="complex" {{#unless (eq activeTab "complex")}}hidden{{/unless}}>
    <div class="points-badge">
      Complex: <strong>{{abilityPointsRemaining}}</strong> / {{abilityPointsTotal}} pts
      <span class="hint">Fraquezas extras (+1 pt, máx 2):</span>
      <input type="number" name="system.extraWeaknesses" value="{{system.extraWeaknesses}}" min="0" max="2"/>
    </div>
    {{#each system.abilities as |ability index|}}
    <div class="ability-card" data-ability-index="{{index}}">
      <div class="ability-header">
        <input type="text" data-ab-field="name" value="{{ability.name}}" placeholder="Nome da habilidade"/>
        <select data-ab-field="type">
          {{#each ../config.abilityTypes as |type typeKey|}}
          <option value="{{typeKey}}" {{#if (eq ability.type typeKey)}}selected{{/if}}>{{type.label}} ({{type.cost}}pt{{#if type.insanity}} · +{{type.insanity}} ins{{/if}})</option>
          {{/each}}
        </select>
        <button type="button" class="btn-use" data-action="useAbility" data-index="{{index}}">Usar</button>
        <button type="button" data-action="removeAbility" data-index="{{index}}">✕</button>
      </div>
      <input type="text" data-ab-field="desc" value="{{ability.desc}}" placeholder="Descrição"/>
      <input type="text" data-ab-field="weakness" value="{{ability.weakness}}" placeholder="Fraqueza obrigatória"/>
      <input type="text" data-ab-field="damage" value="{{ability.damage}}" placeholder="Dado de dano (ex: 1d6)"/>
    </div>
    {{/each}}
    <button type="button" class="btn-add" data-action="addAbility">+ Adicionar Habilidade</button>
  </div>

  <div class="tab items" data-group="primary" data-tab="items" {{#unless (eq activeTab "items")}}hidden{{/unless}}>
    {{#each system.items as |item index|}}
    <div class="item-card" data-item-index="{{index}}">
      <div class="item-slot">SLOT {{add index 1}}</div>
      <div class="item-row">
        <input type="text" data-it-field="name" value="{{item.name}}" placeholder="Nome do item"/>
        <select data-it-field="tier">
          {{#each ../config.itemTiers as |tier tierKey|}}
          <option value="{{tierKey}}" {{#if (eq item.tier tierKey)}}selected{{/if}}>Tier {{tierKey}} — {{tier.label}} ({{tier.bonus}})</option>
          {{/each}}
        </select>
        <button type="button" class="btn-heal" data-action="useHealingItem" data-index="{{index}}" title="Usar como cura (dado do tier)">💊</button>
      </div>
      <input type="text" data-it-field="desc" value="{{item.desc}}" placeholder="Como se relaciona com o Complex?"/>
    </div>
    {{/each}}
  </div>

  <div class="tab rolls" data-group="primary" data-tab="rolls" {{#unless (eq activeTab "rolls")}}hidden{{/unless}}>
    <h3>Testes (D20 + Atributo vs CD)</h3>
    <div class="roll-grid">
      {{#each config.attributes as |attr key|}}
      <button type="button" data-action="rollTest" data-attr="{{key}}" data-cd="12">{{attr.abbr}} CD 12</button>
      {{/each}}
    </div>
    <h3>Ataque</h3>
    <div class="roll-grid">
      <button type="button" class="btn-attack" data-action="rollAttack" data-attr="for">⚔️ Atacar</button>
    </div>
    <p class="hint">Abre um diálogo para escolher atributo, AC do alvo e, opcionalmente, uma habilidade do Complex.</p>
    <h3>Combate</h3>
    <div class="roll-grid">
      <button type="button" data-action="rollInit">Iniciativa (D20 + AGI)</button>
      {{#if system.dying}}
      <button type="button" data-action="rollDying" class="danger">Rolar Sobrevivência (Morrendo)</button>
      {{/if}}
    </div>

    <h3>Cura &amp; Descanso</h3>
    <div class="roll-grid">
      <button type="button" data-action="shortRest">🛏️ Descanso Curto (+RES HP, −5 Ins)</button>
      <button type="button" data-action="longRest">🌙 Descanso Longo (HP cheio, −15 Ins)</button>
    </div>
    <p class="hint">Itens de cura: use o botão 💊 na aba Itens (rola 1d4/1d6/1d8 conforme o tier).</p>

    <h3>Condições</h3>
    <div class="conditions-grid">
      {{#each conditions as |cond|}}
      <button type="button" class="condition-toggle {{#if cond.active}}active{{/if}}" data-action="toggleCondition" data-condition="{{cond.id}}" title="{{cond.hint}}">
        {{cond.name}}
      </button>
      {{/each}}
    </div>

    <h3>Insanidade &amp; Runaway</h3>
    <div class="runaway-box {{#if runawayActive}}is-active{{/if}}">
      <p class="runaway-status" style="color: {{system.insanityColor}}">
        {{system.insanity.value}}/100 · {{system.insanityLabel}}
      </p>

      {{#if canHallucinate}}
        {{#if isGM}}
        <button type="button" class="btn-halluc" data-action="sendHallucination">👁️ Enviar alucinação (privado)</button>
        {{/if}}
      {{/if}}

      {{#if runawayActive}}
        <p class="runaway-note">🐛💢 <strong>Complex Runaway ativo</strong> — o inseto assumiu o controle.</p>
        <button type="button" class="danger" data-action="exitRunaway">Tentar sair (Mente vs CD 14)</button>
      {{else if canRunaway}}
        {{#if runawayUnlocked}}
        <p class="runaway-note">🔓 Runaway desbloqueado pelo Mestre.</p>
        <button type="button" class="btn-attack" data-action="activateRunaway">🐛 Entrar em Complex Runaway</button>
        {{else}}
        <p class="runaway-note locked">🔒 Runaway bloqueado — aguardando desbloqueio do Mestre{{#if isCollapse}} (Colapso!){{/if}}.</p>
        {{#if isGM}}
        <button type="button" class="danger" data-action="unlockRunaway">🔓 Desbloquear Runaway</button>
        {{/if}}
        {{/if}}
      {{else}}
        <p class="hint">O Runaway fica disponível a partir de 75 de Insanidade.</p>
      {{/if}}
    </div>
  </div>
</section>
</div>
